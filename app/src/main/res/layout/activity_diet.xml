<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/bg_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Diet_Activity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.042"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.958"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.03"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.97"/>
    <TextView
        android:id="@+id/tvNutrition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nutrition"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintTop_toTopOf="@id/startHorizontal" />
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thursday, Oct 24"
        android:textStyle="bold"
        android:textColor="@color/low_white"
        app:layout_constraintTop_toBottomOf="@id/tvNutrition"
        app:layout_constraintStart_toStartOf="@id/tvNutrition"/>

    <androidx.cardview.widget.CardView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:backgroundTint="@color/cv_color"
        app:cardCornerRadius="25dp"
        app:layout_constraintTop_toTopOf="@id/startHorizontal"
        app:layout_constraintEnd_toEndOf="@id/endVertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/calender__2_"
            android:layout_gravity="center"/>

    </androidx.cardview.widget.CardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvRemaining"
        android:layout_width="170dp"
        android:layout_height="130dp"
        app:strokeColor="@color/btn_color"
        app:cardCornerRadius="25dp"
        android:backgroundTint="@color/cv_bg_color"
        android:layout_marginTop="15dp"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintTop_toBottomOf="@id/tvDate">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


        <TextView
            android:id="@+id/tvRemaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMAINING"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:textColor="@color/low_white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvNumbersOfKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1,240"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvRemaining"
            app:layout_constraintStart_toStartOf="@id/tvRemaining"/>

        <TextView
            android:id="@+id/tvKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kcal"
            android:textColor="@color/low_white"
            android:layout_marginStart="10dp"
            android:layout_marginTop="7dp"
            app:layout_constraintTop_toTopOf="@id/tvNumbersOfKcal"
            app:layout_constraintStart_toEndOf="@id/tvNumbersOfKcal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15% below avg"
            android:textColor="@color/tv_color"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvNumbersOfKcal"
            app:layout_constraintStart_toStartOf="@id/tvNumbersOfKcal"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvDailyGoal"
        android:layout_width="170dp"
        android:layout_height="130dp"
        app:strokeColor="@color/btn_color"
        app:cardCornerRadius="25dp"
        android:backgroundTint="@color/cv_bg_color"
        app:layout_constraintEnd_toEndOf="@id/endVertical"
        app:layout_constraintTop_toTopOf="@id/cvRemaining">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <TextView
                android:id="@+id/tvDailyGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY GOAL"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:textColor="@color/low_white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvNumbersOfKcal2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2,500"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:layout_marginTop="5dp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tvDailyGoal"
                app:layout_constraintStart_toStartOf="@id/tvDailyGoal"/>

            <TextView
                android:id="@+id/tvKcal2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="kcal"
                android:layout_marginStart="10dp"
                android:textColor="@color/low_white"
                android:layout_marginTop="7dp"
                app:layout_constraintTop_toTopOf="@id/tvNumbersOfKcal2"
                app:layout_constraintStart_toEndOf="@id/tvNumbersOfKcal2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target Set"
                android:textColor="#994DE1"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvNumbersOfKcal2"
                app:layout_constraintStart_toStartOf="@id/tvNumbersOfKcal2"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
    
    
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvProteinIntake"
        android:layout_width="0dp"
        android:layout_height="200dp"
        app:cardCornerRadius="25dp"
        android:layout_marginTop="20dp"
        app:strokeColor="@color/btn_color"
        android:backgroundTint="@color/cv_bg_color"
        app:layout_constraintTop_toBottomOf="@id/cvRemaining"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintEnd_toEndOf="@id/endVertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvProteinIntake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protein Intake"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="30dp"
                android:layout_marginStart="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvDailyGoalPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65% of daily goal reached"
                android:textColor="@color/low_white"
                app:layout_constraintTop_toBottomOf="@id/tvProteinIntake"
                app:layout_constraintStart_toStartOf="@id/tvProteinIntake"/>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="117g"
                android:textSize="18sp"
                android:textColor="@color/btn_color"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tv180g"
                app:layout_constraintTop_toTopOf="@id/tvDailyGoalPercent"/>

            <TextView
                android:id="@+id/tv180g"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/180g"
                android:textColor="@color/low_white"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvDailyGoalPercent"/>

            <ProgressBar
                android:id="@+id/proteinProgress"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:max="180"
                android:progress="117"
                android:layout_marginTop="20dp"
                android:progressDrawable="@drawable/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                app:layout_constraintTop_toBottomOf="@id/tvDailyGoalPercent"
                app:layout_constraintStart_toStartOf="@id/tvDailyGoalPercent"
                app:layout_constraintEnd_toEndOf="@id/tv180g"/>

            <TextView
                android:id="@+id/tvCrabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carbs"
                android:textColor="@color/low_white"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/proteinProgress"
                app:layout_constraintStart_toStartOf="@id/tvProteinIntake"/>

            <TextView
                android:id="@+id/tvCarbsGrams"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="142g/250g"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="55dp"
                app:layout_constraintTop_toTopOf="@id/tvCrabs"
                app:layout_constraintStart_toEndOf="@id/tvCrabs"/>

            <ProgressBar
                android:id="@+id/crabsProgress"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:max="180"
                android:progress="100"
                android:layout_marginTop="20dp"
                android:progressDrawable="@drawable/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                app:layout_constraintTop_toBottomOf="@id/tvCrabs"
                app:layout_constraintStart_toStartOf="@id/tvCrabs"
                app:layout_constraintEnd_toEndOf="@id/tvCarbsGrams"/>

            <TextView
                android:id="@+id/tvFats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fats"
                android:textColor="@color/low_white"
                android:textSize="14sp"
                android:layout_marginEnd="55dp"
                app:layout_constraintTop_toTopOf="@id/tvCrabs"
                app:layout_constraintEnd_toStartOf="@id/tvFatGrams"/>

            <TextView
                android:id="@+id/tvFatGrams"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="142g/250g"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="40dp"
                app:layout_constraintTop_toTopOf="@id/tvCrabs"
                app:layout_constraintEnd_toEndOf="@id/tv180g"/>

            <ProgressBar
                android:id="@+id/fatsProgress"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:max="180"
                android:progress="100"
                android:layout_marginTop="20dp"
                android:progressDrawable="@drawable/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                app:layout_constraintTop_toBottomOf="@id/tvFats"
                app:layout_constraintStart_toStartOf="@id/tvFats"
                app:layout_constraintEnd_toEndOf="@id/tvFatGrams"/>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMealPlan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today's Meal Plan"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cvProteinIntake"
        app:layout_constraintStart_toStartOf="@id/cvProteinIntake"/>

    <TextView
        android:id="@+id/tvEditPlan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Plan"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:textColor="@color/btn_color"
        app:layout_constraintTop_toTopOf="@id/tvMealPlan"
        app:layout_constraintEnd_toEndOf="@id/endVertical"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/tvMealPlan"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintEnd_toEndOf="@id/endVertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvFirstFood"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:cardCornerRadius="25dp"
                app:strokeColor="@color/btn_color"
                android:backgroundTint="@color/cv_bg_color"
                android:layout_marginTop="5dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvImage"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="20dp"
                        android:layout_marginStart="25dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageView
                            android:id="@+id/ivImg1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img1"/>

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvBerries"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oatmeal with \nBerries"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="@id/cvImage"
                        app:layout_constraintStart_toEndOf="@id/cvImage"/>

                    <TextView
                        android:id="@+id/tvInfo1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="320 kcal . 12g Protein"
                        android:textColor="@color/low_white"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tvBerries"
                        app:layout_constraintStart_toStartOf="@id/tvBerries"/>
                    
                    
                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="10dp"
                        app:cardCornerRadius="25dp"
                        android:backgroundTint="@color/cv_color"
                        app:layout_constraintStart_toEndOf="@id/tvBerries"
                        app:layout_constraintTop_toTopOf="@id/tvBerries">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BREAKFAST"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_gravity="center"
                            android:textColor="@color/btn_color"/>

                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvSecFood"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:cardCornerRadius="25dp"
                app:strokeColor="@color/btn_color"
                android:backgroundTint="@color/cv_bg_color"
                android:layout_marginTop="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvFirstFood">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvImage2"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="20dp"
                        android:layout_marginStart="25dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageView
                            android:id="@+id/ivImg2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img2"/>

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvGrilled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grilled Chicken\nSalad"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="@id/cvImage2"
                        app:layout_constraintStart_toEndOf="@id/cvImage2"/>

                    <TextView
                        android:id="@+id/tvInfo2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="450 kcal · 42g Protein"
                        android:textColor="@color/low_white"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tvGrilled"
                        app:layout_constraintStart_toStartOf="@id/tvGrilled"/>


                    <androidx.cardview.widget.CardView
                        android:layout_width="70dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="10dp"
                        app:cardCornerRadius="25dp"
                        android:backgroundTint="#2C2D4E"
                        app:layout_constraintStart_toEndOf="@id/tvGrilled"
                        app:layout_constraintTop_toTopOf="@id/tvGrilled">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LUNCH"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_gravity="center"
                            android:textColor="#A855F7"/>

                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvThirdFood"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:cardCornerRadius="25dp"
                app:strokeColor="@color/btn_color"
                android:backgroundTint="@color/cv_bg_color"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvSecFood">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvImage3"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="20dp"
                        android:layout_marginStart="25dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageView
                            android:id="@+id/ivImg3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img3"/>

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvSalmon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Salmon &amp;\nAsparagus"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="@id/cvImage3"
                        app:layout_constraintStart_toEndOf="@id/cvImage3"/>

                    <TextView
                        android:id="@+id/tvInfo3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="580 kcal · 38g Protein"
                        android:textColor="@color/low_white"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tvSalmon"
                        app:layout_constraintStart_toStartOf="@id/tvSalmon"/>


                    <androidx.cardview.widget.CardView
                        android:layout_width="70dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="10dp"
                        app:cardCornerRadius="25dp"
                        android:backgroundTint="#2C394C"
                        app:layout_constraintStart_toEndOf="@id/tvSalmon"
                        app:layout_constraintTop_toTopOf="@id/tvSalmon">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DINNER"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_gravity="center"
                            android:textColor="@color/low_white"/>

                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>


    <androidx.cardview.widget.CardView
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:cardCornerRadius="45dp"
        android:elevation="2dp"
        android:backgroundTint="@color/btn_color"
        android:layout_marginBottom="60dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@id/endHorizontal"
        app:layout_constraintEnd_toEndOf="@id/endVertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="+"
            android:textStyle="bold"
            android:textSize="25sp"/>
    </androidx.cardview.widget.CardView>

