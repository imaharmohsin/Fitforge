<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    tools:context=".Workout">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.042"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.958"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.03"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.97"/>

    <TextView
        android:id="@+id/backIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/back"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintTop_toTopOf="@id/startHorizontal" />
    <TextView
        android:id="@+id/tvWorkoutCategories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Workout Categories"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@id/endVertical"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintTop_toTopOf="@id/startHorizontal" />

    <TextView
        android:id="@+id/line"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/low_white"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvWorkoutCategories"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintEnd_toEndOf="@id/endVertical"/>

    <com.google.android.material.search.SearchBar
        android:id="@+id/search_bar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Search"
        app:subtitleTextColor="@color/low_white"
        app:titleTextColor="@color/low_white"
        app:navigationIconTint="@color/low_white"
        android:backgroundTint="@color/cv_bg_color"
        app:layout_constraintTop_toBottomOf="@id/line"
        app:layout_constraintStart_toStartOf="@id/startVertical"
        app:layout_constraintEnd_toEndOf="@id/endVertical"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcvChest"
        android:layout_width="171dp"
        android:layout_height="209dp"
        app:cardCornerRadius="25dp"
        app:strokeColor="@color/btn_color"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/search_bar"
        app:layout_constraintStart_toStartOf="@id/startVertical">

        <TextView
            android:id="@+id/dumbleIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/dumble"
            android:elevation="2dp"
            android:layout_marginTop="120dp"
            android:layout_marginStart="20dp"/>

        <TextView
            android:id="@+id/tvChest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chest"
            android:elevation="2dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="150dp"
            android:layout_marginStart="20dp"/>

        <TextView
            android:id="@+id/tvNoOfExerciseChest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 EXERCISES"
            android:textColor="@color/btn_color"
            android:elevation="2dp"
            android:layout_marginTop="175dp"
            android:layout_marginStart="20dp"/>


        <ImageView
            android:id="@+id/ivChestImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/chest"/>

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcvBack"
        android:layout_width="171dp"
        android:layout_height="209dp"
        app:cardCornerRadius="25dp"
        app:strokeColor="@color/btn_color"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/search_bar"
        app:layout_constraintEnd_toEndOf="@id/endVertical">

        <TextView
            android:id="@+id/menuIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/menu"
            android:elevation="2dp"
            android:layout_marginTop="123dp"
            android:layout_marginStart="20dp"/>

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:elevation="2dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="150dp"
            android:layout_marginStart="20dp"/>

        <TextView
            android:id="@+id/tvNoOfExerciseBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 EXERCISES"
            android:textColor="@color/btn_color"
            android:elevation="2dp"
            android:layout_marginTop="175dp"
            android:layout_marginStart="20dp"/>


        <ImageView
            android:id="@+id/ivBackImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/chest"/>

    </com.google.android.material.card.MaterialCardView>



</androidx.constraintlayout.widget.ConstraintLayout>