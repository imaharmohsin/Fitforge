<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════
         APP THEME
    ══════════════════════════════════════════ -->
    <style name="Theme.FitForge" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorAccentCyan</item>
        <item name="colorPrimaryVariant">@color/colorCardDark</item>
        <item name="colorOnPrimary">@color/colorBackground</item>
        <item name="colorSecondary">@color/colorAccentPurple</item>
        <item name="colorSurface">@color/colorCardDark</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBottomNavBg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="bottomNavigationStyle">@style/Widget.FitForge.BottomNavigation</item>
    </style>

    <!-- Required by activity_home.xml line 291 -->
    <style name="NoIndicator" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>

    <!-- ══════════════════════════════════════════
         BASE STYLES
         Every dot-notation chain needs a declared
         base or Android cannot resolve the children
    ══════════════════════════════════════════ -->
    <style name="Widget.FitForge" parent="android:Widget" />
    <style name="Widget.FitForge.Button" parent="Widget.MaterialComponents.Button" />
    <style name="TextStyle.FitForge" parent="android:Widget" />

    <!-- ══════════════════════════════════════════
         BOTTOM NAVIGATION
    ══════════════════════════════════════════ -->
    <style name="Widget.FitForge.BottomNavigation"
        parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/colorBottomNavBg</item>
        <item name="itemRippleColor">@color/colorRipple</item>
    </style>

    <!-- ══════════════════════════════════════════
         CARD VIEW
    ══════════════════════════════════════════ -->
    <style name="Widget.FitForge.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorCardDark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="rippleColor">@color/colorRipple</item>
    </style>

    <!-- ══════════════════════════════════════════
         BUTTON
    ══════════════════════════════════════════ -->
    <style name="Widget.FitForge.Button.Cyan" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/colorBackground</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="backgroundTint">@color/colorAccentCyan</item>
        <item name="cornerRadius">50dp</item>
    </style>

    <!-- ══════════════════════════════════════════
         DAY LABEL (Weekly Chart X-axis)
    ══════════════════════════════════════════ -->
    <style name="DayLabelStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- ══════════════════════════════════════════
         TEXT STYLES
    ══════════════════════════════════════════ -->
    <style name="TextStyle.FitForge.SectionHeader">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.FitForge.Body">
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextStyle.FitForge.Accent">
        <item name="android:textColor">@color/colorAccentCyan</item>
        <item name="android:textSize">13sp</item>
    </style>

</resources>